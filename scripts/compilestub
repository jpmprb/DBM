#!/bin/bash
# ==============================================================================
# SCRIPT DE GERAÇÃO DE STUBS PARA RENEW (Versão Otimizada - compilestub)
# ==============================================================================
# O QUE ESTA SCRIPT FAZ:
# - Encontra a instalação do Renew.
# - Adiciona os ficheiros .jar ao Classpath.
# - Procura por ficheiros .stub na pasta de trabalho atual (caso nenhum seja indicado).
# - Chama a classe 'de.renew.call.StubCompiler' do Renew para gerar os
#   ficheiros Stub necessários para ligar código Java às Redes de Petri.
# ==============================================================================

echo "========================================================"
echo " A GERAR STUBS DO RENEW (compilestub)                   "
echo "========================================================"

# 1. Definir e verificar caminhos
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORK_DIR="$(pwd)" # Pasta de onde a script foi chamada pelo utilizador

# Atualizado para bater certo com a estrutura lado-a-lado
_HOMERENEW_REL_PATH="../renew4.2"
HOMERENEW="$(cd "${SCRIPT_DIR}/${_HOMERENEW_REL_PATH}" && pwd 2>/dev/null)"

# Verifica se a pasta do Renew existe
if [ -z "$HOMERENEW" ] || [ ! -d "$HOMERENEW" ]; then
    echo "[ERRO] Diretório do Renew não encontrado em: ${SCRIPT_DIR}/${_HOMERENEW_REL_PATH}"
    echo "Verifica se a pasta renew4.2 existe na localização correta."
    exit 1
fi

echo " -> Renew encontrado em: $HOMERENEW"
echo " -> Comando Java configurado: java"

# 2. Construir o Classpath (adicionar os .jar necessários)
# Nota: É necessário adaptar as pastas dependendo de onde os .jar do Renew estão guardados
CP=""
for jar in "$HOMERENEW"/*.jar "$HOMERENEW"/libs/*.jar "$HOMERENEW"/plugins/*.jar; do
    if [ -f "$jar" ]; then
        CP="$CP:$jar"
    fi
done
# Remover o primeiro ':' extra
CP="${CP#:}"

# 3. Determinar os ficheiros a compilar
echo "--------------------------------------------------------"

# Se o utilizador não passou argumentos (número de argumentos = 0)
if [ $# -eq 0 ]; then
    echo " -> Nenhum ficheiro especificado. A procurar ficheiros .stub na pasta atual..."
    
    # Ativa a opção nullglob para que *.stub não retorne texto literal se não houver ficheiros
    shopt -s nullglob
    STUB_FILES=( *.stub )
    shopt -u nullglob # Desativa após a utilização por segurança

    # Verifica se o array tem elementos
    if [ ${#STUB_FILES[@]} -eq 0 ]; then
        echo "[AVISO] Não foi encontrado nenhum ficheiro .stub em: $WORK_DIR"
        echo "[INFO] Podes também passar os ficheiros como argumento:"
        echo "       Exemplo: ../../scripts/compilestub ficheiro.stub"
        exit 0
    fi
    
    echo " -> Ficheiro(s) encontrado(s): ${STUB_FILES[*]}"
else
    # Se o utilizador passou argumentos, usamos esses ficheiros
    echo " -> Ficheiro(s) especificado(s) pelo utilizador: $@"
    STUB_FILES=( "$@" )
fi

# 4. Executar o Compilador de Stubs do Renew
echo " -> A iniciar compilação..."

java -cp "$CP" de.renew.call.StubCompiler "${STUB_FILES[@]}"
EXIT_CODE=$?

# 5. Verificar o resultado final
echo "--------------------------------------------------------"
if [ $EXIT_CODE -eq 0 ]; then
    echo "[SUCESSO] Geração de Stubs terminada sem erros."
else
    echo "[ERRO] Falha ao gerar os Stubs. Verifica a sintaxe, dependências ou a mensagem acima."
    exit 1
fi